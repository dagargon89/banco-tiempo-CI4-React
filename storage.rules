rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Documentos de verificación de identidad (cifrados)
    // Cada usuario solo puede escribir en su propia carpeta
    match /privado/identidad/{uid}/{fileName} {
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024;

      // Solo el Admin SDK (backend) puede leer vía signed URLs
      allow read: if false;
    }

    // Bloquear todo lo demás por defecto
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
