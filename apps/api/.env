#--------------------------------------------------------------------
# Banco de Tiempo · API (CodeIgniter 4.7) — plantilla de entorno
# Copiar a `.env` y rellenar. NUNCA versionar el .env real (doc 04).
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

app.baseURL = 'http://localhost:8080/'
app.forceGlobalSecureRequests = false

# MySQL 8 (fuente de verdad)
database.default.hostname = 127.0.0.1
database.default.database = banco_de_tiempo
database.default.username = bt_app
database.default.password = bt_app_local
database.default.DBDriver = MySQLi
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

# Firebase (Auth + Firestore + Storage) — ADR-007/008
# Ruta al archivo de credenciales del Admin SDK, permisos 0600, fuera del repo.
FIREBASE_CREDENTIALS = /home/dagargon89/banco-tiempo-CI4-React/banco-de-tiempo-5e32c-firebase-adminsdk-fbsvc-13284a13a5.json
FIREBASE_PROJECT_ID = banco-de-tiempo-5e32c
FIREBASE_STORAGE_BUCKET = banco-de-tiempo-5e32c.firebasestorage.app

# Cifrado app-side de documentos de identidad (doc 04 A02)
# Generar: php spark key:generate
encryption.key =

# Redis (caché, cola, throttle)
cache.handler = redis
cache.redis.host = 127.0.0.1
cache.redis.port = 6379
cache.redis.password =

# CORS — origen del SPA
CORS_ALLOWED_ORIGIN = http://localhost:5173

# Correo (SMTP)
email.fromEmail = no-reply@bancodetiempo.planjuarez.org
email.fromName = 'Banco de Tiempo'
email.protocol = smtp
email.SMTPHost =
email.SMTPPort = 587
email.SMTPCrypto = tls

# Seed del super-admin: se crea en Firebase Auth y se mapea aquí por su UID
SEED_ADMIN_EMAIL =
SEED_ADMIN_FIREBASE_UID =
SEED_ADMIN_NOMBRE = 'Administrador'
