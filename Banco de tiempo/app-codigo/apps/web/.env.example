# Banco de Tiempo · SPA — plantilla de entorno. Copiar a .env.local
# Solo claves PÚBLICAS (VITE_*). Ningún secreto del backend aquí.
VITE_API_URL=/api/v1

# Config pública del proyecto Firebase (cliente). NO el service account.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=
